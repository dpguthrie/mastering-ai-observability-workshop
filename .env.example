# Required: Braintrust Gateway access.
# Add a Braintrust API key for an org with at least one AI provider configured.
# The app uses this as an OpenAI-compatible API key and automatically points the
# OpenAI client at https://gateway.braintrust.dev.
BRAINTRUST_API_KEY=

# Required: model to use for the agent and evals.
# Choose a Gateway-configured chat model that supports tool/function calling.
AGENT_DEFAULT_MODEL=

# Optional: model to use for LLM judge scorers.
# Leave blank to reuse AGENT_DEFAULT_MODEL.
JUDGE_MODEL=

# Optional: comma-separated model ids for the local chat model picker.
# Leave blank if attendees should only use AGENT_DEFAULT_MODEL.
ADDITIONAL_MODELS=

# Shared sanitized workshop trace bundle used by `make import-sample-traces`.
TRACE_BUNDLE_URL=https://aiewf-braintrust-workshop-bucket.s3.us-east-1.amazonaws.com/workshop/aiewf-sample-traces.tar.gz

# Dataset names used by evals and Makefile helpers.
EVAL_DATASET=support-agent-eval-cases
AIEWF_DRAFT_DATASET=support-flywheel-draft-cases

# Defaults: these can stay as-is for the workshop.
BRAINTRUST_PROJECT=AIE-Workshop
AIEWF_DB_PATH=data/workshop.db
AIEWF_CHAT_CUSTOMER_ID=cus_1002
