    "policies": [
      {
        "policy_key": "returns",
        "title": "Returns",
        "body": "Most non-final-sale items can be returned within the product return window. Final sale items are not returnable. Hazmat items require manual review. Gift returns can be exchanged for store credit after order verification."
      },
      {
        "policy_key": "refunds",
        "title": "Refunds",
        "body": "Refunds require a matching paid order and evidence of return eligibility, shipment loss, duplicate charge, or approved goodwill exception. Orders under manual review, suspended accounts, and authorized-only payments cannot be refunded by the agent."
      },
      {
        "policy_key": "shipping",
        "title": "Shipping exceptions",
        "body": "If a shipment is delayed but still moving, provide status and next scan. Escalate if no scan for 5 business days, delivered-not-received, damaged shipment, or VIP impact. Label-created orders may need fulfillment investigation before refund or replacement."
      },
      {
        "policy_key": "credits",
        "title": "Goodwill credits",
        "body": "Agents may apply up to $15 in store credit for clear inconvenience on active accounts. Higher credits, account review, repeated delivery failures, or chargeback risk require escalation."
      },
      {
        "policy_key": "exchanges",
        "title": "Exchanges",
        "body": "Eligible non-final-sale apparel and footwear may be exchanged within the return window if the original item is unused. Hazmat, fuel, and final-sale outlet products are not exchangeable through self-service."
      },
      {
        "policy_key": "identity",
        "title": "Account and identity boundaries",
        "body": "Agents may only discuss or act on orders for the authenticated customer. Requests involving another customer's order, payment method, address, or refund require identity verification and escalation."
      },
      {
        "policy_key": "cancellations",
        "title": "Cancellations and address changes",
